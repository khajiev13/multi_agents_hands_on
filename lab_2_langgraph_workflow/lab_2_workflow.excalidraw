      "version": 1,
      "versionNonce": 13198,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775927174175,
      "link": null,
      "locked": false,
      "text": "Notebook-first LangGraph view of the BIT flow: instructor-only page-by-page OCR builds the markdown corpus ahead of class, the notebook fans out over local professor markdown to build a persistent Chroma collection, and the supervisor routes questions to retrieval-first workers plus one add-by-URL ingestion worker.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "Notebook-first LangGraph view of the BIT flow: instructor-only page-by-page OCR builds the markdown corpus ahead of class, the notebook fans out over local professor markdown to build a persistent Chroma collection, and the supervisor routes questions to retrieval-first workers plus one add-by-URL ingestion worker.",
      "autoResize": false,
      "lineHeight": 1.25,
      "baseline": 20
    },
