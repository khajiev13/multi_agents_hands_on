BIT_PROF_LLM_API_KEY=your-llm-api-key
BIT_PROF_LLM_BASE_URL=https://api.silra.cn/v1/
BIT_PROF_LLM_MODEL=qwen3.5-plus

BIT_PROF_OCR_API_KEY=your-ocr-api-key
BIT_PROF_OCR_BASE_URL=https://api.silra.cn/v1/
BIT_PROF_OCR_MODEL=qwen-vl-ocr-latest

BIT_PROF_EMBEDDING_API_KEY=your-embedding-api-key
BIT_PROF_EMBEDDING_BASE_URL=https://api.silra.cn/v1/
BIT_PROF_EMBEDDING_MODEL=text-embedding-v4
BIT_PROF_EMBEDDING_DIMS=2048
BIT_PROF_EMBEDDING_BATCH_SIZE=10

BIT_PROF_RERANK_API_KEY=your-rerank-api-key
BIT_PROF_RERANK_BASE_URL=https://api.silra.cn
BIT_PROF_RERANK_MODEL=bge-reranker-v2-m3

BIT_PROF_VECTOR_DIR=artifacts/lab2/chroma

# Required for Lab 3 student seed loading. Lab 1 also uses Neo4j.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-this-password
NEO4J_DATABASE=neo4j
